{
  "name": "vocab-pwa",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "functions/lib/index.js",
  "engines": {
    "node": "22"
  },
  "workspaces": [
    "packages/shared",
    "apps/web",
    "functions"
  ],
  "scripts": {
    "build": "npm run build -ws",
    "test": "npm run test -ws --if-present",
