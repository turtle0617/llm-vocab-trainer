{
  "name": "@vocab/functions",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "backfill:owner": "npm run build && node lib/scripts/backfill-owner.js",
    "reconcile:section-summaries": "npm run build && node lib/scripts/reconcile-section-summaries.js",
    "serve": "npm run serve:persist",
    "serve:persist": "mkdir -p ../.firebase-emulator-data && npm run build && firebase emulators:start --only functions,firestore,hosting,auth --import ../.firebase-emulator-data --export-on-exit ../.firebase-emulator-data",
    "serve:fresh": "npm run build && firebase emulators:start --only functions,firestore,hosting,auth",
    "test": "vitest run",
    "test:integration": "vitest run src/*.integration.test.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@vocab/shared": "*",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "firebase-admin": "^13.4.0",
    "firebase-functions": "^7.2.5",
    "ts-fsrs": "^5.2.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
